######################################################################
# Application Environment Configuration Example (.env.example)
#
# Copy this file to .env and fill in the required values for your environment.
# Never commit your real .env file with secrets to version control.
######################################################################

# ------------------- Server Configuration -------------------
PORT=3000
NODE_ENV=production
APP_DOMAIN=sourcetolive.app  # e.g., localhost:8000 for local development

# ------------------- AWS Configuration ----------------------
AWS_REGION=us-east-1
CLUSTER=                # e.g., my-ecs-cluster
TASK=                   # e.g., my-ecs-task
AWS_SUBNETS=            # Comma-separated subnet IDs
AWS_SECURITY_GROUPS=    # Comma-separated security group IDs
S3_BUCKET=              # e.g., my-app-bucket
AWS_ACCESS_KEY_ID=      # Your AWS access key
AWS_SECRET_ACCESS_KEY=  # Your AWS secret key

# ------------------- Database Configuration -----------------
MONGODB_URI=            # MongoDB connection string

# ------------------- JWT Configuration ---------------------
JWT_SECRET=             # Strong secret for JWT signing

# ------------------- Email Configuration -------------------
# Use a valid Gmail App Password (16 chars, no spaces)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=             # Your email address
EMAIL_PASSWORD=         # Gmail App Password
EMAIL_FROM=             # Displayed as sender

# ------------------- OAuth & API Keys ----------------------
GOOGLE_CLIENT_ID=       # Google OAuth Client ID
GITHUB_CLIENT_ID=       # GitHub OAuth Client ID
GITHUB_CLIENT_SECRET=   # GitHub OAuth Client Secret
GITHUB_CALLBACK_URL=    # e.g., https://yourdomain.com/auth/github/callback

# ------------------- CORS & Frontend -----------------------
CORS_ORIGIN=https://sourcetolive.dev  # Allowed frontend origin
FRONTEND_URL=https://sourcetolive.dev # Frontend base URL

# ------------------- API URL -------------------------------
API_URL=https://api.sourcetolive.dev  # Backend API base URL
