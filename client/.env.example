######################################################################
# Client Environment Configuration Example (.env.example)
#
# Copy this file to .env and fill in the required values for your environment.
# Never commit your real .env file with secrets to version control.
######################################################################

# ------------------- API Configuration -------------------
# Use your local network IP for mobile device access during development
VITE_API_URL=              # e.g., http://localhost:3000

# ------------------- OAuth Configuration -----------------
VITE_GOOGLE_CLIENT_ID=     # Google OAuth Client ID
VITE_GITHUB_CLIENT_ID=     # GitHub OAuth Client ID
VITE_GITHUB_REDIRECT_URI=  # e.g., http://localhost:5173/auth/github/callback
