######################################################################
# Reverse Proxy Environment Configuration Example (.env.example)
#
# Copy this file to .env and fill in the required values for your environment.
# Never commit your real .env file with secrets to version control.
######################################################################

# ------------------- Application Settings -------------------
PORT=8000                                                                # Port for the reverse proxy server
BASE_PATH=https://sourcetolivebucket.s3.us-east-1.amazonaws.com/__outputs  # S3 bucket base path for outputs

# ------------------- AWS Credentials ------------------------
AWS_ACCESS_KEY_ID=         # Your AWS access key
AWS_SECRET_ACCESS_KEY=     # Your AWS secret key
AWS_REGION=us-east-1       # AWS region (default: us-east-1)
