######################################################################
# Build Server Environment Configuration Example (.env.example)
#
# Copy this file to .env and fill in the required values for your environment.
# Never commit your real .env file with secrets to version control.
######################################################################

# ------------------- AWS Credentials ----------------------
AWS_ACCESS_KEY_ID=<your-access-key-id>         # Your AWS access key
AWS_SECRET_ACCESS_KEY=<your-secret-access-key> # Your AWS secret key
AWS_REGION=us-east-1                           # AWS region (default: us-east-1)
